# ---------------------------------------------------------------
#  Google Maps (OPTIONAL)
# ---------------------------------------------------------------
#  Leave these blank to use the free OpenStreetMap/Leaflet map.
#
#  To switch to Google Maps:
#  1. Copy this file to a new file named exactly  .env
#  2. Paste your key after the = sign below.
#  3. Restart the dev server (Ctrl+C, then `npm run dev`).
#
#  How to get a key (free at this site's traffic level):
#  - Go to https://console.cloud.google.com/
#  - Create a project, then enable the "Maps JavaScript API".
#  - APIs & Services > Credentials > Create credentials > API key.
#  - IMPORTANT: click the key > Application restrictions >
#    "Websites", and add your site's address so nobody else can
#    use your key.
# ---------------------------------------------------------------

VITE_GOOGLE_MAPS_API_KEY=

# Optional: a Map ID (Google Cloud > Map Management). Leave blank to
# use Google's built-in demo style.
VITE_GOOGLE_MAPS_MAP_ID=
